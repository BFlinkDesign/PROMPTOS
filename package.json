{
  "name": "promptos",
  "private": true,
  "scripts": {
    "catalog:build": "node tools/build-console-data.mjs --write",
    "catalog:evaluate": "node tools/evaluate-catalog.mjs",
    "capabilities:validate": "node tools/validate-capabilities.mjs",
    "benchmark:evaluator": "node tools/benchmark-evaluator.mjs",
    "benchmark:platform": "node tools/benchmark-platform.mjs",
    "eval:snapshot": "promptfoo eval -o snapshots/promptfoo-results.json",
    "eval:promptfoo": "promptfoo eval",
    "feedback:promote": "node tools/promote.js",
    "feedback:verify": "node tools/verify-feedback.mjs",
    "prompt:quality": "node tools/validate-prompt-quality.mjs",
    "schema:validate": "node tools/validate-items.mjs",
    "test:review-pipeline": "node --test tests/review-pipeline-gate.test.cjs tests/review-pipeline-github.test.cjs",
    "test:console": "playwright test",
    "tool:promptfoo": "promptfoo --version",
    "tool:playwright": "playwright --version",
    "verify": "npm run prompt:quality && npm run benchmark:evaluator && npm run benchmark:platform && npm run capabilities:validate && npm run catalog:evaluate && npm run schema:validate && npm run feedback:verify && npm run test:review-pipeline && npm run eval:promptfoo && npm run test:console"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "ajv": "^8.20.0",
    "promptfoo": "^0.121.18"
  }
}
