{
  "name": "promptos",
  "private": true,
  "scripts": {
    "catalog:build": "node tools/build-console-data.mjs --write",
    "catalog:evaluate": "node tools/evaluate-catalog.mjs",
    "eval:snapshot": "promptfoo eval -o snapshots/promptfoo-results.json",
    "eval:promptfoo": "promptfoo eval",
    "feedback:promote": "node tools/promote.js",
    "feedback:verify": "node tools/verify-feedback.mjs",
    "schema:validate": "node tools/validate-items.mjs",
    "test:console": "playwright test",
    "prompt-engine:test": "node --test prompt-engine/test/*.test.mjs",
    "prompt-engine:demo": "node prompt-engine/src/cli.mjs optimize prompt-engine/fixtures/request.json --provider heuristic",
    "prompt-engine:serve": "node prompt-engine/src/cli.mjs serve --provider heuristic --port 8787",
    "tool:promptfoo": "promptfoo --version",
    "tool:playwright": "playwright --version",
    "verify": "npm run catalog:evaluate && npm run schema:validate && npm run feedback:verify && npm run eval:promptfoo && npm run test:console && npm run prompt-engine:test"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "ajv": "^8.20.0",
    "promptfoo": "^0.121.17"
  }
}
