{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/BFlinkDesign/PROMPTOS/skills/dcc-asset-pipeline/schema/state.schema.json",
  "title": "DCC Asset Pipeline State",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "skill_id",
    "job_id",
    "status",
    "created_at",
    "updated_at",
    "operator_id",
    "target",
    "assets"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "skill_id": { "const": "dcc-asset-pipeline" },
    "job_id": { "$ref": "#/$defs/slug" },
    "status": { "enum": ["active", "blocked", "complete"] },
    "created_at": { "$ref": "#/$defs/timestamp" },
    "updated_at": { "$ref": "#/$defs/timestamp" },
    "operator_id": { "type": "string", "minLength": 1 },
    "target": { "type": "object" },
    "assets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "asset_id",
          "source_path",
          "asset_class",
          "provenance",
          "phase",
          "triangle_budget",
          "texture_max",
          "normal_map_required",
          "metrics",
          "evidence",
          "outputs",
          "verification",
          "waivers",
          "blockers",
          "history"
        ],
        "properties": {
          "asset_id": { "$ref": "#/$defs/slug" },
          "source_path": { "type": "string", "minLength": 1 },
          "asset_class": {
            "enum": [
              "complex-architecture",
              "hero-prop",
              "small-prop",
              "background-filler",
              "animated-skinned"
            ]
          },
          "provenance": { "type": "object" },
          "phase": {
            "enum": [
              "intake",
              "preserved",
              "inspected",
              "optimized",
              "baked",
              "packaged",
              "reimported",
              "verified",
              "complete",
              "quarantined"
            ]
          },
          "triangle_budget": { "type": "integer", "minimum": 1 },
          "texture_max": { "type": "integer", "minimum": 1, "maximum": 16384 },
          "normal_map_required": { "type": "boolean" },
          "metrics": { "type": "object" },
          "evidence": { "type": "object" },
          "outputs": { "type": "object" },
          "verification": { "type": "object" },
          "waivers": { "type": "object" },
          "blockers": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "history": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["action", "from", "to", "actor_id", "at", "note"],
              "properties": {
                "action": { "enum": ["initialize", "advance", "quarantine"] },
                "from": { "type": ["string", "null"] },
                "to": { "type": "string", "minLength": 1 },
                "actor_id": { "type": "string", "minLength": 1 },
                "at": { "$ref": "#/$defs/timestamp" },
                "note": { "type": "string" }
              }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    }
  }
}
