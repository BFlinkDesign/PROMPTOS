{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://promptos.local/schema/engine-evaluation-receipt.schema.json",
  "title": "Prompt Engine evaluation receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "source_prompt_sha256",
    "input_bundle_sha256",
    "dataset_version",
    "dataset_sha256",
    "split_sha256",
    "candidate_sha256",
    "provider",
    "model",
    "model_config_sha256",
    "seed",
    "tool_version",
    "environment",
    "git_commit",
    "artifact_sha256",
    "started_at",
    "completed_at",
    "attempts",
    "duration_ms",
    "usage",
    "claim_state",
    "public_eval",
    "holdout_eval"
  ],
  "properties": {
    "version": { "const": 1 },
    "source_prompt_sha256": { "$ref": "#/$defs/sha256" },
    "input_bundle_sha256": { "$ref": "#/$defs/sha256" },
    "dataset_version": { "type": "string", "minLength": 1 },
    "dataset_sha256": { "$ref": "#/$defs/sha256" },
    "split_sha256": { "$ref": "#/$defs/sha256" },
    "candidate_sha256": { "$ref": "#/$defs/sha256" },
    "provider": { "type": "string", "minLength": 1 },
    "model": { "type": "string", "minLength": 1 },
    "model_config_sha256": { "$ref": "#/$defs/sha256" },
    "seed": {
      "type": ["integer", "null"],
      "minimum": -9007199254740991,
      "maximum": 9007199254740991
    },
    "tool_version": { "type": "string", "minLength": 1 },
    "environment": { "type": "string", "minLength": 1 },
    "git_commit": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
    "artifact_sha256": { "$ref": "#/$defs/sha256" },
    "started_at": { "$ref": "#/$defs/timestamp" },
    "completed_at": { "$ref": "#/$defs/timestamp" },
    "attempts": { "type": "integer", "minimum": 1, "maximum": 9007199254740991 },
    "duration_ms": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
    "usage": { "$ref": "#/$defs/usage" },
    "claim_state": {
      "enum": [
        "STATIC-VALID",
        "PUBLIC-EVAL-PASSED"
      ]
    },
    "public_eval": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/passAggregate" }
      ]
    },
    "holdout_eval": { "type": "null" }
  },
  "allOf": [
    {
      "if": {
        "required": ["claim_state"],
        "properties": { "claim_state": { "const": "STATIC-VALID" } }
      },
      "then": { "properties": { "public_eval": { "type": "null" } } }
    },
    {
      "if": {
        "required": ["claim_state"],
        "properties": { "claim_state": { "const": "PUBLIC-EVAL-PASSED" } }
      },
      "then": { "properties": { "public_eval": { "$ref": "#/$defs/passAggregate" } } }
    }
  ],
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "timestamp": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "passAggregate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["failed", "total", "dataset_sha256", "split_sha256"],
      "properties": {
        "failed": { "const": 0 },
        "total": { "type": "integer", "minimum": 1, "maximum": 9007199254740991 },
        "dataset_sha256": { "$ref": "#/$defs/sha256" },
        "split_sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "usage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source",
        "input_tokens",
        "output_tokens",
        "cost_usd",
        "pricing_version"
      ],
      "properties": {
        "source": { "enum": ["reported", "estimated", "unknown"] },
        "input_tokens": {
          "type": ["integer", "null"],
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "output_tokens": {
          "type": ["integer", "null"],
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "cost_usd": { "type": ["number", "null"], "minimum": 0 },
        "pricing_version": { "type": ["string", "null"] }
      },
      "allOf": [
        {
          "if": {
            "required": ["source"],
            "properties": { "source": { "const": "unknown" } }
          },
          "then": {
            "properties": {
              "cost_usd": { "const": null },
              "pricing_version": { "const": null }
            }
          }
        },
        {
          "if": {
            "required": ["source"],
            "properties": { "source": { "const": "estimated" } }
          },
          "then": {
            "properties": {
              "cost_usd": { "type": "number", "minimum": 0 },
              "pricing_version": { "type": "string", "minLength": 1 }
            }
          }
        },
        {
          "if": {
            "required": ["source"],
            "properties": { "source": { "const": "reported" } }
          },
          "then": {
            "properties": {
              "cost_usd": { "type": "number", "minimum": 0 }
            }
          }
        }
      ]
    }
  }
}
