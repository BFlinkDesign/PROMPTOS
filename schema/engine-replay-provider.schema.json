{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://promptos.local/schema/engine-replay-provider.schema.json",
  "title": "Prompt Engine offline replay provider",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "provider", "model", "responses"],
  "properties": {
    "version": { "const": 1 },
    "provider": { "const": "offline-replay" },
    "model": { "type": "string", "minLength": 1 },
    "responses": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["case_id", "input_sha256", "output", "usage"],
        "properties": {
          "case_id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "input_sha256": { "$ref": "#/$defs/sha256" },
          "output": { "type": "string" },
          "usage": {
            "type": "object",
            "additionalProperties": false,
            "required": ["input_tokens", "output_tokens", "provider_cost_usd"],
            "properties": {
              "input_tokens": { "type": "integer", "minimum": 0 },
              "output_tokens": { "type": "integer", "minimum": 0 },
              "provider_cost_usd": { "type": "number", "minimum": 0 }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
  }
}
