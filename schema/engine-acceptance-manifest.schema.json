{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://promptos.local/schema/engine-acceptance-manifest.schema.json",
  "title": "Prompt Engine acceptance manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "manifest_id",
    "created_at",
    "public_dataset",
    "holdout_contract",
    "offline_replay_provider",
    "baselines",
    "pricing",
    "limits",
    "claim_states"
  ],
  "properties": {
    "version": { "const": 1 },
    "manifest_id": { "const": "prompt-engine-acceptance-v1" },
    "created_at": { "$ref": "#/$defs/timestamp" },
    "public_dataset": { "$ref": "#/$defs/fileRef" },
    "holdout_contract": { "$ref": "#/$defs/fileRef" },
    "offline_replay_provider": { "$ref": "#/$defs/fileRef" },
    "baselines": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["prompt_path", "prompt_sha256"],
        "properties": {
          "prompt_path": { "type": "string", "pattern": "^prompts/[a-z0-9-]+\\.md$" },
          "prompt_sha256": { "$ref": "#/$defs/sha256" }
        }
      }
    },
    "pricing": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "version",
        "effective_at",
        "source",
        "input_usd_per_million",
        "output_usd_per_million"
      ],
      "properties": {
        "version": { "type": "string", "minLength": 1 },
        "effective_at": { "$ref": "#/$defs/timestamp" },
        "source": { "type": "string", "minLength": 1 },
        "input_usd_per_million": { "type": "number", "minimum": 0 },
        "output_usd_per_million": { "type": "number", "minimum": 0 }
      }
    },
    "limits": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "timeout_ms",
        "max_attempts",
        "max_tokens",
        "max_cost_usd",
        "require_known_cost"
      ],
      "properties": {
        "timeout_ms": { "type": "integer", "minimum": 1 },
        "max_attempts": { "type": "integer", "minimum": 1, "maximum": 10 },
        "max_tokens": { "type": "integer", "minimum": 1 },
        "max_cost_usd": { "type": "number", "minimum": 0 },
        "require_known_cost": { "type": "boolean" }
      }
    },
    "claim_states": {
      "type": "array",
      "const": [
        "STATIC-VALID",
        "PUBLIC-EVAL-PASSED",
        "BASELINE-WIN",
        "HOLDOUT-WIN",
        "INDEPENDENTLY-BENCHMARKED"
      ]
    }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "timestamp": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "fileRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    }
  }
}
